# Sanity Project Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API Token (write access — keep secret, never commit)
SANITY_API_TOKEN=your_sanity_api_token_here

# On-demand revalidation secret (generate a random string)
SANITY_REVALIDATE_SECRET=your_revalidation_secret_here

# Site URL (used for canonical URLs and OG meta)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
